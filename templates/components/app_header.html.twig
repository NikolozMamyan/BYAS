<style>
    .app-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9998;
        min-height: 68px;
        padding: 12px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        background: rgba(11, 14, 20, 0.88);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .app-header__brand {
        color: white;
        text-decoration: none;
        font-size: 1.55rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0;
        text-transform: uppercase;
        background: linear-gradient(to bottom, #fff, #FF007A);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .app-header__meta {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        text-align: right;
    }

    .app-header__identity {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .app-header__actions {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-left: auto;
    }

    .app-header__icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.05);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        position: relative;
        cursor: pointer;
        padding: 0;
        appearance: none;
    }

    .app-header__badge {
        position: absolute;
        top: -6px;
        right: -6px;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        background: #FF007A;
        color: white;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 0.62rem;
        font-weight: 900;
        border: 2px solid rgba(11, 14, 20, 0.96);
    }

    .app-header__badge.is-visible {
        display: inline-flex;
    }

    .app-header__avatar,
    .app-header__avatar.avatar-placeholder {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        object-fit: cover;
        flex: 0 0 auto;
        border: 1px solid rgba(255,255,255,0.12);
    }

    .app-header__avatar.avatar-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(255,0,122,0.28), rgba(0,242,255,0.22));
        color: white;
        font-weight: 900;
    }

    .app-header__label {
        color: #00F2FF;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .app-header__user {
        color: rgba(255,255,255,0.72);
        font-size: 0.78rem;
        font-weight: 700;
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .notif-panel {
        position: absolute;
        top: calc(100% + 10px);
        right: 18px;
        width: min(360px, calc(100vw - 24px));
        max-height: min(72vh, 560px);
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(14, 18, 26, 0.98);
        box-shadow: 0 20px 50px rgba(0,0,0,0.42);
        display: none;
    }

    .notif-panel.is-open {
        display: block;
    }

    .notif-panel__shell {
        max-height: inherit;
        overflow: auto;
        padding: 10px;
    }

    .notif-panel__head,
    .notif-panel__footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 6px 12px;
    }

    .notif-panel__muted {
        color: rgba(255,255,255,0.6);
        font-size: 0.74rem;
    }

    .notif-panel__list {
        display: grid;
        gap: 8px;
    }

    .notif-panel .feed-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        text-decoration: none;
        color: inherit;
    }

    .notif-panel .feed-item.is-unread {
        border-color: rgba(0,242,255,0.18);
        background: rgba(0,242,255,0.05);
    }

    .notif-panel .feed-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.05);
    }

    .notif-panel .feed-content {
        min-width: 0;
    }

    .notif-panel .feed-title {
        font-size: 0.8rem;
        font-weight: 800;
    }

    .notif-panel .muted,
    .notif-panel .feed-time {
        color: rgba(255,255,255,0.6);
        font-size: 0.72rem;
    }

    .notif-panel .feed-time {
        white-space: nowrap;
    }

    .notif-panel .feed-unread {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 6px;
        color: #00F2FF;
        font-size: 0.68rem;
        font-weight: 800;
    }

    .notif-panel__empty {
        min-height: 160px;
        display: grid;
        place-items: center;
        gap: 8px;
        color: rgba(255,255,255,0.68);
        text-align: center;
        padding: 18px;
    }

    .notif-panel__button,
    .notif-panel__link {
        color: #00F2FF;
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 800;
    }

    @media (min-width: 768px) {
        .app-header {
            padding: 14px 32px;
        }

        .app-header__brand {
            font-size: 1.8rem;
        }

        .app-header__user {
            max-width: 260px;
        }
    }
</style>

<header
    class="app-header"
    data-controller="notifications-panel"
    data-notifications-panel-url-value="{{ path('app_front_notifications_panel') }}"
>
    <a href="{{ path('app_front_passport') }}" class="app-header__brand">BYAS</a>
    <div class="app-header__actions">
        <button
            type="button"
            class="app-header__icon"
            aria-label="Notifications"
            data-action="notifications-panel#toggle"
            data-notifications-panel-target="button"
        >
            <i class="fas fa-bell"></i>
            <span class="app-header__badge" data-notifications-panel-target="badge"></span>
        </button>
        <a href="{{ path('app_front_passport_settings') }}" class="app-header__icon" aria-label="Settings">
            <i class="fas fa-gear"></i>
        </a>
    </div>
    <div class="app-header__identity">
        {% include 'components/user_avatar.html.twig' with {
            avatarUrl: app.user.avatarUrl,
            displayName: app.user.displayName|default(app.user.userIdentifier),
            avatarClass: 'app-header__avatar'
        } only %}
        <div class="app-header__meta">
            <span class="app-header__label">Fandom Passport</span>
            <span class="app-header__user">{{ app.user.displayName|default(app.user.userIdentifier) }}</span>
        </div>
    </div>
    <div class="notif-panel" data-notifications-panel-target="panel" hidden>
        <div class="notif-panel__shell" data-notifications-panel-target="content">
            <div class="notif-panel__empty">
                <i class="fas fa-spinner fa-spin"></i>
                <div>Loading notifications...</div>
            </div>
        </div>
    </div>
</header>
