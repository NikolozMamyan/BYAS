{% extends 'base.html.twig' %}

{% block title %}BYAS | Connect Apple Music{% endblock %}

{% block stylesheets %}
<style>
    body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background:
            radial-gradient(circle at 15% 12%, rgba(255, 0, 122, 0.14), transparent 26%),
            radial-gradient(circle at 86% 8%, rgba(0, 242, 255, 0.10), transparent 25%),
            linear-gradient(180deg, #0B0E14 0%, #0E121A 100%);
        color: #fff;
        font-family: 'Outfit', 'Inter', sans-serif;
        padding: 24px;
    }

    .apple-connect {
        width: min(420px, 100%);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        padding: 22px;
        box-shadow: 0 18px 42px rgba(0,0,0,0.28);
        display: grid;
        gap: 14px;
    }

    .kicker {
        color: #00F2FF;
        font-size: 0.72rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        font-size: 1.8rem;
        line-height: 1;
    }

    p {
        margin: 0;
        color: rgba(255,255,255,0.68);
        line-height: 1.45;
        font-size: 0.9rem;
    }

    .btn {
        min-height: 48px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: #fff;
        color: #000;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
    }

    .status {
        min-height: 18px;
        color: #00F2FF;
        font-size: 0.8rem;
        font-weight: 700;
    }
</style>
{% endblock %}

{% block body %}
<main
    class="apple-connect"
    data-controller="apple-music-connect"
    data-apple-music-connect-developer-token-value="{{ developerToken }}"
    data-apple-music-connect-app-name-value="{{ appName }}"
    data-apple-music-connect-link-url-value="{{ linkUrl }}"
    data-apple-music-connect-csrf-token-value="{{ csrfToken }}"
>
    <div class="kicker">Apple Music</div>
    <h1>Connect your Apple Music account</h1>
    <p>Authorize Apple Music to bring your recent listening into BYAS. This flow uses MusicKit on the web.</p>
    <button type="button" class="btn" data-apple-music-connect-target="button" data-action="apple-music-connect#connect">Connect Apple Music</button>
    <div class="status" data-apple-music-connect-target="status"></div>
</main>

<script src="https://js-cdn.music.apple.com/musickit/v3/musickit.js"></script>
{% endblock %}
