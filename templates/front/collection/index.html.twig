{% extends 'base.html.twig' %}

{% block title %}Ma collection{% endblock %}

{% block body %}
    <style>
        .collection-page {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .collection-header {
            margin-bottom: 32px;
        }

        .collection-header h1 {
            margin-bottom: 8px;
        }

        .collection-header p {
            margin: 0;
            opacity: 0.8;
        }

        .shelf-block {
            margin-bottom: 42px;
        }

        .shelf-title {
            margin-bottom: 14px;
            font-size: 1.3rem;
        }

        .shelf {
            position: relative;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 18px;
            padding: 18px 18px 28px;
            background: linear-gradient(to bottom, #f8f8f8 0%, #eeeeee 100%);
            border-radius: 14px;
            box-shadow: inset 0 -8px 0 rgba(0,0,0,0.06);
        }

        .shelf::after {
            content: "";
            position: absolute;
            left: 12px;
            right: 12px;
            bottom: 10px;
            height: 10px;
            border-radius: 8px;
            background: #b07d4f;
        }

        .collection-card {
            position: relative;
            z-index: 1;
            min-height: 220px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 14px;
            border-radius: 12px;
            background: white;
            box-shadow: 0 6px 16px rgba(0,0,0,0.08);
        }

        .collection-type {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            opacity: 0.7;
            margin-bottom: 8px;
        }

        .collection-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 8px;
            line-height: 1.3;
        }

        .collection-artist {
            font-size: 0.92rem;
            margin-bottom: 10px;
            opacity: 0.85;
        }

        .collection-desc {
            font-size: 0.85rem;
            line-height: 1.35;
            opacity: 0.8;
            margin-bottom: 12px;
        }

        .collection-footer {
            font-size: 0.8rem;
            opacity: 0.75;
        }

        .empty-state {
            padding: 30px;
            border-radius: 14px;
            background: #f7f7f7;
        }
    </style>

    <div class="collection-page">
        <div class="collection-header">
            <h1>Ma collection</h1>
            <p>
                Le mur de collection de {{ user.displayName }} — {{ items|length }} objet{{ items|length > 1 ? 's' : '' }}
            </p>
        </div>

        {% if shelves is empty %}
            <div class="empty-state">
                Aucun objet dans la collection pour le moment.
            </div>
        {% else %}
            {% for shelfName, shelfItems in shelves %}
                <section class="shelf-block">
                    <h2 class="shelf-title">{{ shelfName }}</h2>

                    <div class="shelf">
                        {% for item in shelfItems %}
                            <article class="collection-card">
                                <div>
                                    <div class="collection-type">
                                        {{ item.type ? item.type.label : 'Objet' }}
                                    </div>

                                    <div class="collection-title">
                                        {{ item.title }}
                                    </div>

                                    <div class="collection-artist">
                                        {{ item.artist ? item.artist.name : 'Sans artiste lié' }}
                                    </div>

                                    {% if item.description %}
                                        <div class="collection-desc">
                                            {{ item.description }}
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="collection-footer">
                                    Quantité : {{ item.quantity }}<br>
                                    Déclaré le {{ item.declaredAt|date('d/m/Y') }}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}