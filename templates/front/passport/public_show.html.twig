{% extends 'base.html.twig' %}

{% block title %}BYAS | {{ profile.username|default(user.displayName) }}{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --bg-deep: #0B0E14;
        --bg-soft: #111520;
        --neon-pink: #FF007A;
        --neon-cyan: #00F2FF;
        --soft-purple: #9D50BB;
        --text-main: #FFFFFF;
        --text-dim: rgba(255,255,255,0.66);
        --line: rgba(255,255,255,0.12);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background:
            radial-gradient(circle at 15% 12%, rgba(255, 0, 122, 0.16), transparent 28%),
            radial-gradient(circle at 85% 6%, rgba(0, 242, 255, 0.12), transparent 26%),
            linear-gradient(180deg, #0B0E14 0%, #0E121A 100%);
        color: var(--text-main);
        font-family: 'Outfit', 'Inter', sans-serif;
        padding: 18px 14px 40px;
    }

    .public-passport {
        width: min(720px, 100%);
        margin: 0 auto;
        display: grid;
        gap: 16px;
    }

    .public-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-height: 52px;
    }

    .brand {
        color: white;
        text-decoration: none;
        font-size: 1.7rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0;
        text-transform: uppercase;
        background: linear-gradient(to bottom, #fff, var(--neon-pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .public-label {
        color: var(--neon-cyan);
        font-size: 0.7rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .passport-card,
    .section-card,
    .cta-card {
        border-radius: 8px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.045);
        box-shadow: 0 18px 42px rgba(0,0,0,0.28);
    }

    .passport-card {
        padding: 18px;
        display: grid;
        gap: 18px;
        background:
            linear-gradient(135deg, rgba(255,0,122,0.16), transparent 36%),
            linear-gradient(45deg, rgba(0,242,255,0.12), transparent 42%),
            rgba(255,255,255,0.045);
    }

    .identity {
        display: grid;
        grid-template-columns: 78px minmax(0, 1fr);
        align-items: center;
        gap: 14px;
    }

    .avatar {
        width: 78px;
        height: 78px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--neon-pink), var(--soft-purple), var(--neon-cyan));
        font-size: 1.6rem;
        font-weight: 900;
    }

    h1 {
        margin: 0;
        font-size: 2.1rem;
        line-height: 1;
        letter-spacing: 0;
        word-break: break-word;
    }

    .muted {
        color: var(--text-dim);
        font-size: 0.88rem;
        line-height: 1.45;
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .stat {
        min-width: 0;
        border-radius: 8px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.05);
        padding: 12px;
    }

    .stat small {
        display: block;
        color: rgba(255,255,255,0.56);
        text-transform: uppercase;
        font-size: 0.64rem;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .stat strong {
        display: block;
        font-size: 1rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .xp-bar {
        height: 9px;
        background: rgba(255,255,255,0.12);
        border-radius: 8px;
        overflow: hidden;
    }

    .xp-bar span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--neon-pink), var(--neon-cyan));
    }

    .section-card,
    .cta-card {
        padding: 16px;
    }

    .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;
    }

    .section-head h2 {
        margin: 0;
        font-size: 1rem;
        letter-spacing: 0;
    }

    .list {
        display: grid;
        gap: 10px;
    }

    .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 11px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .row strong {
        display: block;
        font-size: 0.92rem;
    }

    .pill {
        flex: 0 0 auto;
        border-radius: 8px;
        border: 1px solid rgba(0, 242, 255, 0.28);
        color: var(--neon-cyan);
        background: rgba(0, 242, 255, 0.08);
        padding: 7px 9px;
        font-size: 0.72rem;
        font-weight: 900;
    }

    .cta-card {
        display: grid;
        gap: 12px;
        background: rgba(0, 242, 255, 0.06);
        border-color: rgba(0, 242, 255, 0.22);
    }

    .cta-card a {
        display: inline-flex;
        justify-content: center;
        border-radius: 8px;
        padding: 12px 14px;
        color: #061014;
        background: var(--neon-cyan);
        text-decoration: none;
        font-weight: 900;
    }

    .private-box {
        min-height: 70vh;
        display: grid;
        place-items: center;
    }

    @media (max-width: 560px) {
        .stats {
            grid-template-columns: 1fr;
        }

        .identity {
            grid-template-columns: 70px minmax(0, 1fr);
        }

        .avatar {
            width: 70px;
            height: 70px;
        }

        h1 {
            font-size: 1.75rem;
        }
    }
</style>
{% endblock %}

{% block body %}
{% set displayName = profile.username|default(user.displayName) %}
<main class="public-passport">
    <div class="public-top">
        <a href="{{ path('app_landing') }}" class="brand">BYAS</a>
        <span class="public-label">Public Passport</span>
    </div>

    {% if isPrivate %}
        <section class="private-box">
            <div class="cta-card">
                <h1>This Passport is private.</h1>
                <p class="muted">The fan has chosen not to share public Passport details.</p>
                <a href="{{ path('show_register') }}">Create your BYAS Passport</a>
            </div>
        </section>
    {% else %}
        <section class="passport-card">
            <div class="identity">
                <div class="avatar">{{ displayName|slice(0, 2)|upper }}</div>
                <div>
                    <h1>{{ displayName }}</h1>
                    <p class="muted">Level {{ user.globalLevel }} fan with {{ user.globalXp }} XP</p>
                </div>
            </div>

            <div class="stats">
                <div class="stat">
                    <small>Global Rank</small>
                    <strong>{{ globalRank ? '#' ~ globalRank : 'Hidden' }}</strong>
                </div>
                <div class="stat">
                    <small>Top Fandom</small>
                    <strong>{{ fandoms|length and fandoms[0].artist ? fandoms[0].artist.name : 'None yet' }}</strong>
                </div>
                <div class="stat">
                    <small>Badges</small>
                    <strong>{{ profile.showBadges ? userBadges|length : 'Hidden' }}</strong>
                </div>
            </div>

            <div class="xp-bar" aria-label="Global progress">
                <span style="width: {{ globalProgress.percent }}%;"></span>
            </div>
        </section>

        {% if profile.showFandomLevels %}
            <section class="section-card">
                <div class="section-head">
                    <h2>Top Fandoms</h2>
                    <span class="pill">{{ fandoms|length }}</span>
                </div>
                <div class="list">
                    {% for fandom in fandoms %}
                        <div class="row">
                            <div>
                                <strong>{{ fandom.artist ? fandom.artist.name : 'Artist' }}</strong>
                                <span class="muted">{{ fandom.xp }} XP</span>
                            </div>
                            <span class="pill">Level {{ fandom.level }}</span>
                        </div>
                    {% else %}
                        <div class="row">
                            <span class="muted">No public fandom yet.</span>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if profile.showBadges %}
            <section class="section-card">
                <div class="section-head">
                    <h2>Badges</h2>
                    <span class="pill">{{ userBadges|length }}</span>
                </div>
                <div class="list">
                    {% for userBadge in userBadges %}
                        <div class="row">
                            <div>
                                <strong>{{ userBadge.badge.name }}</strong>
                                <span class="muted">{{ userBadge.awardedAt|date('M d, Y') }}</span>
                            </div>
                            <span class="pill">Earned</span>
                        </div>
                    {% else %}
                        <div class="row">
                            <span class="muted">No public badge yet.</span>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section class="cta-card">
            <strong>Want to message {{ displayName }}?</strong>
            <p class="muted">Join BYAS to connect with fans. Messaging will unlock in the social layer.</p>
            <a href="{{ path('show_register', { intent: 'message', passport: profile.shareSlug }) }}">Join BYAS to message</a>
        </section>
    {% endif %}
</main>
{% endblock %}
