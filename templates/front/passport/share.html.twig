{% extends 'base.html.twig' %}

{% block title %}BYAS | Share Card{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --bg-deep: #0B0E14;
        --bg-soft: #111520;
        --neon-pink: #FF007A;
        --neon-cyan: #00F2FF;
        --soft-purple: #9D50BB;
        --text-main: #FFFFFF;
        --text-dim: rgba(255,255,255,0.66);
        --line: rgba(255,255,255,0.14);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background: #080a0f;
        color: var(--text-main);
        font-family: 'Outfit', 'Inter', sans-serif;
        display: grid;
        place-items: center;
        padding: 92px 14px 96px;
    }

    .share-page {
        width: 100%;
        display: grid;
        gap: 14px;
        justify-items: center;
    }

    .story-card {
        width: min(360px, 100%);
        aspect-ratio: 9 / 16;
        position: relative;
        overflow: hidden;
        border-radius: 8px;
        background:
            linear-gradient(155deg, rgba(255, 0, 122, 0.34) 0%, transparent 32%),
            linear-gradient(28deg, rgba(0, 242, 255, 0.28) 0%, transparent 36%),
            linear-gradient(180deg, #171b28 0%, #0B0E14 100%);
        border: 1px solid rgba(255,255,255,0.18);
        padding: 22px;
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 16px;
        box-shadow: 0 24px 70px rgba(0,0,0,0.38);
        isolation: isolate;
        color: #fff;
    }

    .story-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            repeating-linear-gradient(135deg, rgba(255,255,255,0.035) 0 1px, transparent 1px 24px),
            radial-gradient(circle at 80% 12%, rgba(255,255,255,0.12), transparent 22%);
        pointer-events: none;
        z-index: -1;
    }

    .share-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .brand {
        font-size: 1.45rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0;
        text-transform: uppercase;
        background: linear-gradient(to bottom, #fff, var(--neon-pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .rank-pill {
        border: 1px solid rgba(0, 242, 255, 0.34);
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 0.78rem;
        font-weight: 900;
        color: #00F2FF;
        background: rgba(0, 242, 255, 0.08);
    }

    .hero-zone {
        display: grid;
        align-content: center;
        gap: 18px;
    }

    .identity-row {
        display: grid;
        grid-template-columns: 78px minmax(0, 1fr);
        gap: 14px;
        align-items: center;
    }

    .avatar-initials {
        width: 78px;
        height: 78px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: 1.65rem;
        font-weight: 900;
        color: #fff;
        background: linear-gradient(135deg, var(--neon-pink), var(--soft-purple), var(--neon-cyan));
        border: 1px solid rgba(255,255,255,0.34);
        box-shadow: 0 12px 26px rgba(255,0,122,0.2);
    }

    .name {
        margin: 0;
        font-size: 2.15rem;
        line-height: 0.98;
        letter-spacing: 0;
        word-break: break-word;
    }

    .level {
        margin-top: 8px;
        font-size: 0.92rem;
        color: var(--text-dim);
        font-weight: 800;
    }

    .xp-panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 12px;
        background: rgba(255,255,255,0.06);
    }

    .xp-head {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
        font-size: 0.74rem;
        color: var(--text-dim);
        font-weight: 800;
        text-transform: uppercase;
    }

    .xp-bar {
        height: 10px;
        background: rgba(255,255,255,0.14);
        border-radius: 8px;
        overflow: hidden;
    }

    .xp-bar span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--neon-pink), var(--neon-cyan));
        border-radius: inherit;
    }

    .share-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .share-stat {
        min-height: 80px;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 11px;
        background: rgba(255,255,255,0.055);
        display: grid;
        align-content: space-between;
    }

    .share-stat small {
        display: block;
        color: rgba(255,255,255,0.58);
        text-transform: uppercase;
        font-size: 0.64rem;
        font-weight: 900;
        letter-spacing: 0;
        margin-bottom: 6px;
    }

    .share-stat strong {
        display: block;
        font-size: 1.04rem;
        line-height: 1.15;
        word-break: break-word;
    }

    .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 10px;
    }

    .badge {
        border: 1px solid rgba(0, 242, 255, 0.34);
        border-radius: 8px;
        padding: 7px 9px;
        font-size: 0.7rem;
        font-weight: 900;
        color: #00F2FF;
        background: rgba(0, 242, 255, 0.08);
        max-width: 100%;
    }

    .story-bottom {
        display: grid;
        grid-template-columns: 1fr 86px;
        gap: 12px;
        align-items: end;
    }

    .caption {
        color: rgba(255,255,255,0.72);
        font-size: 0.8rem;
        line-height: 1.35;
        font-weight: 700;
    }

    .qr-box {
        width: 86px;
        height: 86px;
        border-radius: 8px;
        padding: 7px;
        background: #fff;
        display: grid;
        place-items: center;
    }

    .qr-box canvas,
    .qr-box img {
        width: 72px !important;
        height: 72px !important;
        display: block;
    }

    .share-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .share-actions a,
    .share-actions button {
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 8px;
        padding: 10px 14px;
        background: rgba(255,255,255,0.06);
        color: #fff;
        text-decoration: none;
        font: inherit;
        cursor: pointer;
        font-weight: 800;
    }

    .share-actions button.primary {
        background: #00F2FF;
        color: #061014;
        border-color: #00F2FF;
    }

    .share-note {
        max-width: 360px;
        color: rgba(255,255,255,0.58);
        font-size: 0.75rem;
        text-align: center;
        line-height: 1.35;
    }

    @media print {
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body {
            padding: 0;
            background: #111520 !important;
            display: grid;
            place-items: center;
        }

        .app-header,
        .bottom-nav,
        .share-actions,
        .share-note {
            display: none !important;
        }

        .story-card {
            width: 100vw;
            height: 100vh;
            max-width: none;
            aspect-ratio: auto;
            border: 0;
            box-shadow: none;
        }
    }

    @media (max-width: 560px) {
        body {
            padding-left: 10px;
            padding-right: 10px;
        }

        .story-card {
            padding: 18px;
            gap: 12px;
        }

        .name {
            font-size: 1.82rem;
        }

        .identity-row {
            grid-template-columns: 70px minmax(0, 1fr);
            gap: 12px;
        }

        .avatar-initials {
            width: 70px;
            height: 70px;
        }
    }
</style>
{% endblock %}

{% block body %}
{% set displayName = profile.username|default(user.displayName) %}
<main class="share-page" data-controller="share-export" data-share-export-url-value="{{ shareUrl }}">
    <section class="story-card" id="shareCard" data-share-export-target="card">
        <div class="share-top">
            <div class="brand">BYAS</div>
            <div class="rank-pill">Global #{{ globalRank }}</div>
        </div>

        <div class="hero-zone">
            <div class="identity-row">
                <div class="avatar-initials">{{ displayName|slice(0, 2)|upper }}</div>
                <div>
                    <h1 class="name">{{ displayName }}</h1>
                    <div class="level">Level {{ user.globalLevel }} &middot; {{ user.globalXp }} XP</div>
                </div>
            </div>

            <div class="xp-panel">
                <div class="xp-head">
                    <span>Global Progress</span>
                    <span>{{ globalProgress.percent|round }}%</span>
                </div>
                <div class="xp-bar" aria-label="Global progress">
                    <span style="width: {{ globalProgress.percent }}%;"></span>
                </div>
            </div>

            <div>
                <div class="share-stats">
                    <div class="share-stat">
                        <small>Top Fandom</small>
                        <strong>{{ topFandom and topFandom.artist ? topFandom.artist.name : 'No fandom yet' }}</strong>
                    </div>
                    <div class="share-stat">
                        <small>Fandom Level</small>
                        <strong>{{ topFandom ? 'Level ' ~ topFandom.level : '-' }}</strong>
                    </div>
                </div>

                <div class="badge-row">
                    {% for userBadge in userBadges %}
                        <span class="badge">{{ userBadge.badge.name }}</span>
                    {% else %}
                        <span class="badge">First badge loading</span>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="story-bottom">
            <div class="caption">Scan the code to open this BYAS Passport story.</div>
            <div class="qr-box" id="shareQr" aria-label="QR code" data-share-export-target="qr"></div>
        </div>
    </section>

    <div class="share-actions">
        <a href="{{ path('app_front_passport') }}">Back to Passport</a>
        <button type="button" class="primary" id="downloadStory" data-share-export-target="download" data-action="share-export#download">Download PNG</button>
        <button type="button" data-action="share-export#print">Save as PDF</button>
    </div>

    <p class="share-note" id="shareExportStatus" data-share-export-target="status">PNG export uses the story card only, with dark colors preserved.</p>
</main>

<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
{% endblock %}
